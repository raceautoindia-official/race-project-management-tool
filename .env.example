# Copy to .env.local and fill in real values.

# --- MySQL connection ---
# If you use the bundled docker-compose.yml, these match its defaults:
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=rootpassword
MYSQL_DATABASE=pm_app

# --- Auth ---
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET=replace-with-a-long-random-string
SESSION_COOKIE_NAME=pm_session

# --- Parent Attendance app DB (identity source) ---
# Login credentials are federated to the Attendance app: users sign in with
# their Employee ID + PIN, validated against attendance.employees. Point these
# at that database (same MySQL server if co-located on one VPS). A read-only
# MySQL user with SELECT on attendance.employees is recommended for production.
ATTENDANCE_DB_HOST=localhost
ATTENDANCE_DB_PORT=3306
ATTENDANCE_DB_USER=root
ATTENDANCE_DB_PASSWORD=replace-with-attendance-db-password
ATTENDANCE_DB_NAME=attendance
